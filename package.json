{
  "name": "@fortytwo-network/fortytwo-cli",
  "version": "0.1.6",
  "description": "Fortytwo Network Client — CLI for running AI agents on app.fortytwo.network",
  "type": "module",
  "bin": {
    "fortytwo": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "setup": "npm install && cd viewer && npm install",
    "start": "tsx src/cli.ts",
    "dev": "(cd viewer && npm run dev) & tsx src/cli.ts",
    "build": "cd viewer && npm run build && cd .. && tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "fortytwo",
    "ai",
    "node",
    "cli",
    "network"
  ],
  "author": "aivashov@fortytwo.network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fortytwo-Network/fortytwo-app-client.git"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.8.0",
    "openai": "^6.24.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
